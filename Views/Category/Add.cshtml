@model BaiTapThucHanh.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<style>
    .basketball-form-header {
        background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
        color: #ff6b35;
        padding: 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
    }
    
    .basketball-form-header h1 {
        margin: 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .form-label {
        font-weight: 600;
        color: #1a1a1a;
    }
    
    .form-control {
        border: 2px solid #e8e8e8;
        transition: all 0.3s ease;
    }
    
    .form-control:focus {
        border-color: #ff6b35;
        box-shadow: 0 0 0 0.2rem rgba(255, 107, 53, 0.25);
    }
    
    .btn-basketball {
        background-color: #ff6b35;
        border-color: #ff6b35;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .btn-basketball:hover {
        background-color: #ff8c00;
        border-color: #ff8c00;
        transform: translateY(-2px);
        color: white;
        box-shadow: 0 6px 12px rgba(255, 107, 53, 0.3);
    }
</style>

<div class="basketball-form-header">
    <h1><i class="bi bi-plus-circle me-2"></i>Thêm danh mục mới</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Add" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"><i class="bi bi-folder-fill me-1 text-danger"></i>Tên danh mục</label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Giày Nike, Giày Adidas..." />
                <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3 d-flex gap-2">
                <button type="submit" class="btn btn-basketball px-4">
                    <i class="bi bi-check-circle me-2"></i>Thêm danh mục
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </form>
    </div>
</div>