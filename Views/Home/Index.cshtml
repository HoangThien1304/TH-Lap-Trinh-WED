@model IEnumerable<BaiTapThucHanh.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - Cửa hàng giày bóng rổ";
    // Lấy danh sách danh mục từ ViewBag đã gửi qua từ Controller
    var categories = ViewBag.Categories as List<BaiTapThucHanh.Models.Category>;
    var currentCategoryId = ViewBag.CurrentCategoryId as int?;
}

<style>
    /* STYLE PHONG CÁCH BASKETBALL TRẺ TRUNG NĂNG ĐỘNG */

    /* Cấu hình các nút lọc Danh mục */
    .btn-br-filter {
        font-weight: 700;
        transition: all 0.3s ease;
        border: 2px solid #ff6b35;
        color: #ff6b35;
        background-color: transparent;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
    }

        .btn-br-filter:hover {
            background-color: #ff6b35 !important;
            border-color: #ff6b35 !important;
            color: #ffffff !important;
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(255, 107, 53, 0.3);
        }
        /* Nút danh mục đang được active chọn */
        .btn-br-filter.active-br {
            background: linear-gradient(135deg, #ff6b35, #ffc107) !important;
            border-color: #ff6b35 !important;
            color: #ffffff !important;
            box-shadow: 0 6px 16px rgba(255, 107, 53, 0.4);
        }

    /* Hiệu ứng mượt mà cho Card sản phẩm */
    .br-product-card {
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 2px solid transparent !important;
        background: #ffffff;
        overflow: hidden;
    }

        .br-product-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 16px 32px rgba(0, 0, 0, 0.15) !important;
            border-color: #ff6b35 !important;
        }

    /* Tiêu đề phần nổi bật */
    .br-title-border {
        border-left: 5px solid #ff6b35;
        padding-left: 12px;
        color: #1a1a1a;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Nút bấm xem chi tiết */
    .btn-samba {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        color: #ffffff;
        font-weight: 700;
        border: none;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
    }

    .br-product-card:hover .btn-samba {
        background: linear-gradient(135deg, #ff6b35, #ff8c00) !important;
        color: #ffffff;
        transform: translateY(-2px);
    }

    /* Filter section styling */
    .filter-section {
        background: linear-gradient(135deg, rgba(255, 107, 53, 0.05), rgba(255, 193, 7, 0.05)) !important;
        border: 2px solid #ff6b35 !important;
        border-radius: 12px;
    }
</style>

<div class="container py-4">

    <!-- Phần Header Tên Website và Các Nút Điều Hướng -->
    <div class="mb-5 text-center py-5 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); color: white; border-bottom: 6px solid #ff6b35;">
        <h1 class="display-4 fw-bold mb-2" style="letter-spacing: 3px; font-weight: 900; text-transform: uppercase;">SNEAKER BASKETBALL</h1>
        <p class="lead mb-4" style="color: #ff6b35; font-weight: 600;">JUST DO IT</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light px-4 py-2 fw-bold rounded-pill border-2">TRANG CHỦ</a>
            <a asp-controller="Product" asp-action="Index" class="btn px-4 py-2 fw-bold rounded-pill text-white" style="background-color: #ff6b35; border-color: #ff6b35;">SẢN PHẨM</a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-light px-4 py-2 fw-bold rounded-pill border-2">LIÊN HỆ</a>
        </div>
    </div>

    <div class="mb-6 p-4 filter-section rounded-3 shadow-sm">
        <h5 class="fw-bold mb-4 text-dark text-uppercase" style="letter-spacing: 1px;">
            <i class="bi bi-funnel-fill text-danger me-2"></i> Bộ lọc sản phẩm
        </h5>
        <div class="d-flex flex-wrap gap-3">
            <a asp-action="Index" asp-route-categoryId=""
               class="btn btn-br-filter rounded-pill px-4 @(currentCategoryId == null || currentCategoryId == 0 ? "active-br" : "")">
                <i class="bi bi-collection-fill me-2"></i> Tất cả
            </a>

            @if (categories != null && categories.Any())
            {
                foreach (var cat in categories)
                {
                    <a asp-action="Index" asp-route-categoryId="@cat.Id"
                       class="btn btn-br-filter rounded-pill px-4 @(currentCategoryId == cat.Id ? "active-br" : "")">
                        <i class="bi bi-shoe me-2"></i> @cat.Name
                    </a>
                }
            }
        </div>
    </div>

    <h2 class="pb-3 mb-5 text-dark fw-bold br-title-border">
        <i class="bi bi-fire text-danger me-2"></i> Sản phẩm nổi bật
    </h2>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm rounded-3 overflow-hidden br-product-card">

                        <div class="text-center bg-light p-4 position-relative" style="height: 220px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f5f5f5, #e8e8e8);">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="/images/@product.ImageUrl" class="card-img-top" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@product.Name" />
                            }
                            else
                            {
                                <div class="text-muted text-center">
                                    <i class="bi bi-shoe" style="font-size: 3.5rem; color: #ff6b35;"></i><br />
                                    <span style="font-size: 0.85rem; color: #666;">Không có ảnh</span>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column pt-4">
                            <h5 class="card-title text-dark fw-bold mb-2" style="font-size: 1.15rem; line-height: 1.4;">@product.Name</h5>

                            <div class="mb-3">
                                @if (product.Category != null)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 rounded-pill" style="font-size: 0.85rem;">
                                        <i class="bi bi-tag-fill me-1"></i>@product.Category.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border px-3 py-2 rounded-pill">Chưa phân loại</span>
                                }
                            </div>

                            <p class="card-text text-muted text-truncate small mb-4" title="@product.Description" style="color: #666;">
                                @product.Description
                            </p>

                            <div class="mt-auto pt-3 border-top border-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-danger fw-bold" style="font-size: 1.3rem;">@product.Price.ToString("#,##0")<small style="font-size: 0.7rem;">đ</small></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer p-0 border-top-0">
                            <a asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-samba w-100 py-3 rounded-0 rounded-bottom text-center d-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-eye-fill"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 w-100 text-center text-muted py-5">
                <div class="p-5 rounded-3 border-2 border-dashed" style="border-color: #ff6b35 !important; background: rgba(255, 107, 53, 0.05);">
                    <i class="bi bi-inbox text-danger mb-3" style="font-size: 3rem;"></i>
                    <p class="fs-5 m-0 fw-semibold text-dark">Không tìm thấy sản phẩm nào</p>
                    <small class="text-muted">Hãy chọn danh mục khác để xem thêm</small>
                </div>
            </div>
        }
    </div>
</div>