@model IEnumerable<BaiTapThucHanh.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<style>
    .basketball-header {
        background: linear-gradient(135deg, #a51313, #dd0c0c);
        color: #ff6b35;
        padding: 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
    }
    
    .basketball-header h2 {
        margin: 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .btn-basketball {
        background-color: #ff6b35;
        border-color: #ff6b35;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .btn-basketball:hover {
        background-color: #ff8c00;
        border-color: #ff8c00;
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(255, 107, 53, 0.3);
    }
    
    .table-hover tbody tr:hover {
        background-color: rgba(255, 107, 53, 0.08);
    }
</style>

<div class="basketball-header">
    <h2><i class="bi bi-shoe me-2"></i>Danh sách sản phẩm</h2>
</div>

<p>
    <a asp-action="Add" class="btn btn-basketball">
        <i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
    </a>
</p>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light text-center">
        <tr style="background-color: #f5f5f5;">
            <th style="width: 20%; color: #1a1a1a;"><i class="bi bi-tag me-1"></i>Tên sản phẩm</th>
            <th style="width: 15%; color: #1a1a1a;"><i class="bi bi-image me-1"></i>Hình ảnh</th>
            <th style="width: 15%; color: #1a1a1a;"><i class="bi bi-folder me-1"></i>Danh mục</th>
            <th style="width: 15%; color: #1a1a1a;"><i class="bi bi-cash-coin me-1"></i>Giá bán</th>
            <th style="width: 15%; color: #1a1a1a;"><i class="bi bi-chat-left me-1"></i>Mô tả</th>
            <th style="width: 20%; color: #1a1a1a;"><i class="bi bi-lightning me-1"></i>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <tr>
                    <td class="fw-bold text-dark">@product.Name</td>
                    <td class="text-center">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="/images/@product.ImageUrl" width="80" height="80" class="img-thumbnail" style="object-fit: cover; border: 2px solid #ff6b35;" alt="@product.Name" />
                        }
                        else
                        {
                            <span class="text-muted text-italic" style="font-size: 0.85rem;">Không có ảnh</span>
                        }
                    </td>

                    <td class="text-center">
                        @if (product.Category != null)
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2">@product.Category.Name</span>
                        }
                        else
                        {
                            <span class="text-muted small">Chưa phân loại</span>
                        }
                    </td>

                    <td class="text-end text-danger fw-bold" style="font-size: 1.1rem;">
                        @product.Price.ToString("#,##0") <small>đ</small>
                    </td>
                    <td>
                        <span class="text-truncate d-inline-block" style="max-width: 180px; color: #666;" title="@product.Description">
                            @product.Description
                        </span>
                    </td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm" title="Xem chi tiết"><i class="bi bi-eye-fill"></i> Xem</a>
                            <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-outline-warning btn-sm" title="Chỉnh sửa"><i class="bi bi-pencil-fill"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm" title="Xóa"><i class="bi bi-trash-fill"></i> Xóa</a>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted p-4">
                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                    <p class="mt-2 mb-0">Hiện chưa có sản phẩm nào trong hệ thống.</p>
                </td>
            </tr>
        }
    </tbody>
</table>