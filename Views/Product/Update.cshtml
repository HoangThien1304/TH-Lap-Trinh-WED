@model BaiTapThucHanh.Models.Product

<style>
    .basketball-form-header {
        background: linear-gradient(135deg, #1a1a1a, #2d2d2d);
        color: #ff6b35;
        padding: 2rem;
        border-radius: 12px;
        margin-bottom: 2rem;
    }
    
    .basketball-form-header h2 {
        margin: 0;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .form-label {
        font-weight: 600;
        color: #1a1a1a;
    }
    
    .form-control, .form-select {
        border: 2px solid #e8e8e8;
        transition: all 0.3s ease;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #ff6b35;
        box-shadow: 0 0 0 0.2rem rgba(255, 107, 53, 0.25);
    }
    
    .btn-basketball {
        background-color: #ff6b35;
        border-color: #ff6b35;
        color: white;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .btn-basketball:hover {
        background-color: #ff8c00;
        border-color: #ff8c00;
        transform: translateY(-2px);
        color: white;
        box-shadow: 0 6px 12px rgba(255, 107, 53, 0.3);
    }
</style>

<div class="basketball-form-header">
    <h2><i class="bi bi-pencil-fill me-2"></i>Chỉnh sửa sản phẩm</h2>
</div>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Update" enctype="multipart/form-data" class="card p-4 shadow-sm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label"><i class="bi bi-tag me-1 text-danger"></i>Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="form-label"><i class="bi bi-folder me-1 text-danger"></i>Danh mục sản phẩm</label>
                <select asp-for="CategoryId" class="form-control form-select" asp-items="ViewBag.Categories">
                    <option value="">-- Chọn danh mục sản phẩm --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Price" class="form-label"><i class="bi bi-cash-coin me-1 text-danger"></i>Giá bán</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label"><i class="bi bi-chat-left me-1 text-danger"></i>Mô tả sản phẩm</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ImageFile" class="form-label"><i class="bi bi-image me-1 text-danger"></i>Hình ảnh sản phẩm</label>

                <div class="mb-3 p-3 bg-light rounded">
                    <p class="text-muted small mb-2">Hình ảnh hiện tại:</p>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="/images/@Model.ImageUrl" width="150" height="150" class="img-thumbnail" style="object-fit: cover; border: 2px solid #ff6b35;" alt="@Model.Name" />
                    }
                    else
                    {
                        <p class="text-muted text-italic small mb-0">Sản phẩm này chưa có hình ảnh.</p>
                    }
                </div>

                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger small d-block mt-1"></span>
                <small class="text-muted d-block mt-2">Để trống nếu bạn muốn giữ nguyên hình ảnh cũ.</small>
            </div>

            <div class="form-group d-flex gap-2">
                <button type="submit" class="btn btn-basketball px-4">
                    <i class="bi bi-check-circle me-2"></i>Cập nhật
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}