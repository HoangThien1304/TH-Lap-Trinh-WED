@model IEnumerable<BaiTapThucHanh.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container py-4">
    <h2 class="br-title-border mb-4"><i class="bi bi-cart4 me-2"></i>GIỎ HÀNG CỦA BẠN</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm rounded-4 overflow-hidden bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th>Giá</th>
                        <th style="width: 150px;">Số lượng</th>
                        <th>Thành tiền</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="row-@item.ProductId">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="/images/@item.ImageUrl" class="cart-item-img me-3" alt="@item.ProductName">
                                    <span class="fw-bold text-dark">@item.ProductName</span>
                                </div>
                            </td>
                            <td class="text-danger fw-semibold">@item.Price.ToString("N0") <small>đ</small></td>
                            <td>
                                <div class="input-group input-group-sm">
                                    <button class="btn btn-outline-secondary btn-qty update-qty" data-id="@item.ProductId" data-change="-1">-</button>
                                    <input type="text" class="form-control text-center qty-input" value="@item.Quantity" readonly>
                                    <button class="btn btn-outline-secondary btn-qty update-qty" data-id="@item.ProductId" data-change="1">+</button>
                                </div>
                            </td>
                            <td class="text-danger fw-bold" id="total-@item.ProductId">@((item.Price * item.Quantity).ToString("N0")) <small>đ</small></td>
                            <td class="text-center">
                                <a asp-controller="Cart" asp-action="Remove" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger rounded-pill">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 p-4 rounded-4 bg-dark text-white shadow">
            <h4 class="mb-0 text-uppercase fw-bold">Tổng cộng:</h4>
            <h3 class="mb-0 text-warning fw-black" id="cart-grand-total">@Model.Sum(i => i.Price * i.Quantity).ToString("N0") đ</h3>
        </div>

        <div class="mt-4 d-flex gap-3">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark px-4 py-2 rounded-pill fw-bold">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
            <button class="btn btn-danger px-5 py-2 rounded-pill fw-bold shadow-sm ms-auto" style="background-color: #ff6b35; border: none;">
                THANH TOÁN NGAY <i class="bi bi-credit-card-2-back-fill ms-2"></i>
            </button>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
            <p class="fs-4 mt-3">Giỏ hàng của bạn đang trống!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-danger rounded-pill px-5 mt-3" style="background-color: #ff6b35;">ĐI MUA SẮM NGAY</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(".update-qty").click(function() {
            var btn = $(this);
            var id = btn.data("id");
            var change = btn.data("change");
            var currentQty = parseInt(btn.siblings(".qty-input").val());
            var newQty = currentQty + change;

            if(newQty > 0) {
                $.post("@Url.Action("UpdateQuantity", "Cart")", { id: id, quantity: newQty }, function(res) {
                    if(res.success) {
                        btn.siblings(".qty-input").val(newQty);
                        $("#total-" + id).html(res.total.toLocaleString() + " <small>đ</small>");
                        $("#cart-grand-total").text(res.cartTotal.toLocaleString() + " đ");
                    }
                });
            }
        });
    </script>
}