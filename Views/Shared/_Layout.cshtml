﻿<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sneaker Kingdom | Cửa Hàng Giày Sneaker Chuyên Nghiệp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BaiTapThucHanh.styles.css" asp-append-version="true" />

    <style>
        /* === PHONG CÁCH BASKETBALL TRẺ TRUNG NĂNG ĐỘNG === */
        body {
        background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
        font-family: 'Poppins', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* HEADER - Nền gradient đen & cam hiện đại */
        .br-top-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        padding: 1.5rem 1rem;
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        position: relative;
        }

        /* LOGO LỚNVÀ ĐỘC ĐÁO */
        .br-brand-giant {
        color: #ff6b35 !important;
        font-weight: 900;
        letter-spacing: 1px;
        font-size: 2.5rem;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
        }

        .br-brand-giant:hover {
        color: #ffc107 !important;
        transform: scale(1.05);
        text-shadow: 0 0 20px rgba(255, 107, 53, 0.6);
        }

        /* THANH MENU - Màu đen bóng bẩy */
        .br-navbar-bottom {
        background-color: #0d0d0d !important;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25) !important;
        padding: 0.8rem 1rem;
        border-bottom: 3px solid #ff6b35;
        }

        /* MENU LINKS - Trẻ trung với hiệu ứng hover */
        .br-nav-link {
        color: rgba(255, 255, 255, 0.85) !important;
        font-weight: 600;
        padding: 0.7rem 1.2rem !important;
        margin: 0 0.3rem;
        border-radius: 8px;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        }

        .br-nav-link:hover {
        background-color: #ff6b35 !important;
        color: #ffffff !important;
        transform: translateY(-3px);
        box-shadow: 0 6px 12px rgba(255, 107, 53, 0.3);
        }

        .br-nav-link.active {
        background: linear-gradient(135deg, #ff6b35, #ffc107) !important;
        color: #ffffff !important;
        box-shadow: 0 4px 10px rgba(255, 107, 53, 0.4);
        }

        /* HAMBURGER MENU */
        .br-toggler {
        border-color: rgba(255, 107, 53, 0.7) !important;
        padding: 0.4rem;
        }

        .br-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 107, 53, 1%29' stroke-width='2' stroke-linecap='round' stroke-miterlimit='10' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        /* IDENTITY LINKS */
        .br-navbar-bottom .nav-link:not(.br-nav-link) {
        color: #ffc107 !important;
        font-weight: 600;
        }

        .br-navbar-bottom .nav-link:not(.br-nav-link):hover {
        color: #ff6b35 !important;
        }

        .br-navbar-bottom .btn-link {
        color: #ffc107 !important;
        text-decoration: none;
        font-weight: 600;
        }

        .br-navbar-bottom .btn-link:hover {
        color: #ff6b35 !important;
        }

        /* FOOTER - Đen với accent cam */
        .br-footer {
        background-color: #0d0d0d;
        color: rgba(255,255,255,0.7) !important;
        padding: 1.5rem 0;
        margin-top: 5rem;
        border-top: 4px solid #ff6b35 !important;
        }

        .br-footer a {
        color: #ff6b35;
        text-decoration: none;
        font-weight: bold;
        }

        .br-footer a:hover {
        color: #ffc107;
        text-decoration: underline;
        }
    </style>
</head>
<body>
    <header class="mb-4">
        <div class="br-top-header text-center">
            <div class="container d-flex align-items-center justify-content-center flex-wrap">
                <a class="br-brand-giant" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-basket2-fill me-2"></i>SNEAKER KINGDOM
                </a>
            </div>
        </div>

        <nav class="navbar navbar-expand-lg navbar-dark br-navbar-bottom">
            <div class="container">
                <div class="d-flex align-items-center order-lg-last">
                    <a href="/Cart" class="nav-link text-white me-3 position-relative" title="Giỏ hàng">
                        <i class="bi bi-cart-fill fs-4 text-warning"></i>
                        <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.7rem;">
                            0
                        </span>
                    </a>
                    <button class="navbar-toggler br-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon br-toggler-icon"></span>
                        <span class="text-warning small ms-1">MENU</span>
                    </button>
                </div>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between text-center">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link br-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill me-1"></i> Trang Chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link br-nav-link" asp-area="" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i> Sản Phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link br-nav-link" asp-area="" asp-controller="Home" asp-action="Contact">
                                <i class="bi bi-telephone-fill me-1"></i> Liên Hệ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link br-nav-link" asp-area="" asp-controller="Product" asp-action="Add">
                                <i class="bi bi-plus-circle-fill me-1"></i> Thêm Sản Phẩm Mới
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link br-nav-link" asp-area="" asp-controller="Category" asp-action="Index">
                                <i class="bi bi-tags-fill me-1"></i> Quản Lý Danh Mục
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center justify-content-center mt-2 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container shadow-sm bg-white rounded-3 p-4 min-vh-100">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="br-footer text-center">
        <div class="container">
            <p class="mb-1">&copy; 2026 - <strong>Sneaker Kingdom</strong> - Cửa Hàng Giày Sneaker Chuyên Nghiệp</p>
            <small>Chính sách bảo mật: <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Cập nhật số lượng giỏ hàng khi load trang
        $.get("/Cart/GetCartCount", function(data) {
            $("#cart-count").text(data.count);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>