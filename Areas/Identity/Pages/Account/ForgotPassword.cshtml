@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    body:has(#account) h1::after { content: "QUÊN MẬT KHẨU" !important; }
</style>

<h1>@ViewData["Title"]</h1>

<form id="account" method="post" style="width: 100%; max-width: 500px;">
    <h2>Quên mật khẩu</h2>
    <hr />
    <p class="text-center text-muted mb-4">Nhập email của bạn để lấy lại mật khẩu.</p>
    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
    <div class="form-floating mb-3">
        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
        <label asp-for="Input.Email" class="form-label">Email</label>
        <span asp-validation-for="Input.Email" class="text-danger"></span>
    </div>
    <button type="submit" class="w-100 btn btn-lg btn-primary mt-3">Đặt lại mật khẩu</button>
    <div class="text-center mt-4">
        <p class="mb-2">
            <a asp-page="./Login">Quay lại đăng nhập</a>
        </p>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
